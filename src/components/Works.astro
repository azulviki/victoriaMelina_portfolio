<style>
/* --- 1. SECCIÓN PRINCIPAL --- */
#works-section {
  position: relative;
  z-index: 1;
  padding: 2rem 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  min-height: 100dvh;
  background: transparent !important;
}

/* --- 2. CONTENEDOR CON BLUR --- */
#works-track-wrapper {
  background: rgba(00, 00, 00, 0.55); 
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 1.5rem;
  width: 99vw;                 /* <- Subido a 99vw para ocupar casi todo el ancho */
  max-width: 1920px;           /* <- Subido a 1920px para monitores grandes */
  overflow: hidden;
  position: relative;
}

/* --- 3. EL TRACK (Forzado a comportarse como una grilla rígida) --- */
#works-track {
  display: grid !important;
  grid-auto-flow: column !important;
  grid-auto-columns: 100% !important; 
  height: 100% !important;
  width: auto !important;
}

/* --- 4. EL SLIDE --- */
.work-slide {
  position: relative;
  width: 100% !important;
  height: 100% !important;
  box-sizing: border-box !important;
  
  display: flex !important;
  flex-direction: column !important;
  justify-content: flex-start !important;
  align-items: center !important;
  
  padding: 1.5rem 0.75rem 0 0.75rem !important; 
  min-height: 0 !important;
}

.slide-photo {
  position: absolute;
  top: 0;
  left: 0;
  width: 100% !important;
  height: 100% !important;
  object-fit: cover !important;
}

.work-slide[data-hidden="true"] {
  display: none !important;
}

.slide-content {
  display: flex !important;
  flex-direction: column !important;
  width: 100% !important;
  height: 100% !important;
  align-items: center !important;
  min-height: 0 !important;
}


/* --- 5. EL VIDEO --- */
.slide-video {
  position: relative;
  width: 100% !important;
  
  aspect-ratio: auto !important;      
  
  height: 68dvh !important;    
  max-height: 68dvh !important;
  
  border-radius: 1rem;        
  overflow: hidden;
  background: #000;
  z-index: 2;
  flex-shrink: 1 !important;
  min-height: 0 !important;
}

.slide-video iframe {
  position: absolute;
  top: 0;
  left: 0;
  width: 100% !important;
  height: 100% !important;
  object-fit: cover !important;
  pointer-events: auto;       
}

/* --- 6. TEXTOS (Alineados milimétricamente con el video) --- */
.slide-info {
  position: relative;
  width: 100% !important;
  box-sizing: border-box !important;
  padding: 1.5rem 0.25rem 2.5rem !important;
  text-align: left !important;
  z-index: 3;
  flex-shrink: 0 !important;
}

/* =========================================================
   MOBILE (Menos de 768px)
   ========================================================= */

@media (max-width: 767px) {
  #works-section {
    padding: 0 !important;
  }

  #works-track-wrapper {
  background: rgba(0, 0, 0, 0.55);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 1.5rem;
  width: 100%;
  max-width: 1600px;
  margin: 0 auto;

  overflow-x: auto !important;
  overflow-y: hidden !important;
  scroll-snap-type: x mandatory !important;
  -webkit-overflow-scrolling: touch;
  position: relative;
}
#works-track {
  display: flex !important;
  width: max-content !important;
}

#works-track-wrapper::-webkit-scrollbar {
  display: none !important;
}

  #works-track-wrapper::-webkit-scrollbar {
    display: none !important;
  }

  .work-slide {
  scroll-snap-align: start !important;
  scroll-snap-stop: always !important;
  width: 100vw !important;
  flex: 0 0 100vw !important;
  height: 100% !important;
  padding: 0rem !important; 
  display: flex !important;
  flex-direction: column !important;
}

  .slide-video {
    width: 100vw !important;
    flex: 0 1 65%;
    height: auto !important;
    max-height: 65%;
    min-height: 0;
    border-radius: 0rem !important; 
  }

  .slide-info {
    padding: 1.2rem 1.2rem 2rem 1.2rem !important; 
    flex: 1 1 auto;
    max-height: none !important;
    overflow-y: auto !important; 
    width: 100% !important;
    -webkit-overflow-scrolling: touch;
  }

  .works-nav-btn {
    display: none !important;
  }
}

/* --- COMPUTADORAS (Desktop) --- */
@media (min-width: 768px) {
  #works-track-wrapper {
    max-width: 1600px;
  }

  .work-slide {
    padding-left: 2rem !important;
    padding-right: 2rem !important;
    padding-top: 1rem !important;
  }

  .slide-video {
    height: 75dvh !important;    
    max-height: 75dvh !important;
    flex-shrink: 1 !important;
    min-height: 0 !important;
  }

  .slide-info {
    flex: 1 1 auto;
    min-height: 0;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  #works-prev {
    left: 0.5rem !important;        
  }
  #works-next {
    right: 0.5rem !important;       
  }
  .works-nav-btn {
    padding: 0.75rem !important;
  }

  .works-nav-btn svg {
    width: 48px !important;
    height: 48px !important;
  }
}

/* --- CELULARES (Mobile) --- */
@media (max-width: 767px) {
  .works-nav-btn {
    top: 32% !important;
    width: 20px !important;         
    height: 20px !important;
    background: transparent !important; 
    border: none !important;        
    padding: 0 !important;
  }
  
  .works-nav-btn svg {
    width: 14px !important;
    height: 14px !important;
    opacity: 0.7;
    filter: drop-shadow(0px 1px 3px rgba(0,0,0,0.9));
  }
  
  #works-prev {
    left: 0.4rem !important;       
  }
  #works-next {
    right: 0.4rem !important;      
  }

  .work-slide {
    padding-left: 0rem !important;
    padding-right: 0rem !important;
    padding-top: 0.5rem !important;
  }

  .slide-info {
    padding: 0.8rem 1rem 1.5rem 1rem !important;
  }
}

.slide-tool {
  font-family: 'Space Mono', monospace;
  font-size: 0.8em;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--violet, #7b2fff);
  margin-bottom: 0.5rem;
}

.slide-title {
  font-family: 'Montserrat', sans-serif;
  font-weight: 200;
  font-size: clamp(1.4rem, 3.5vw, 2.2rem);
  line-height: 1.2;
  color: #fff;
  margin-bottom: 0.5rem;
}

.slide-desc {
  font-family: 'Space Mono', monospace;
  font-size: 0.9rem;
  line-height: 1.5;
  color: rgba(255,255,255,0.6);
  max-width: 650px;
}

/* --- 7. BOTONES Y FILTROS --- */
.works-filter {
  color: rgba(255,255,255,0.25);
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
}
.works-filter:hover { color: rgba(255,255,255,0.6); }
.works-filter.active { color: var(--violet, #7b2fff); }

.works-nav-btn {
  color: rgba(255,255,255,0.25);
  background: none;
  border: none;
  cursor: pointer;
  transition: color 0.2s;
  padding: 0.5rem;
}
.works-nav-btn:hover { color: rgba(255,255,255,0.8); }
.works-nav-btn:disabled { opacity: 0.1; cursor: default; }

.works-dot {
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  transition: background 0.3s, transform 0.3s;
  cursor: pointer;
  border: none;
  padding: 0;
}
.works-dot.active {
  background: var(--violet, #7b2fff);
  transform: scale(1.5);
}
</style>

<script>
  import { gsap } from 'gsap';
 
  let currentFilter = 'all';
  let currentIndex  = 0;
 
  const track      = document.getElementById('works-track')!;
  const dotsEl     = document.getElementById('works-dots')!;
  const prevBtn    = document.getElementById('works-prev') as HTMLButtonElement;
  const nextBtn    = document.getElementById('works-next') as HTMLButtonElement;
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.works-filter');
  const allSlides  = Array.from(document.querySelectorAll<HTMLElement>('.work-slide'));
 
  // ── Control de reproducción de video (YouTube + Vimeo) ──────────────
  function pauseAllVideos(exceptIframe?: HTMLIFrameElement) {
    document.querySelectorAll<HTMLIFrameElement>('.slide-video iframe').forEach(iframe => {
      if (exceptIframe && iframe === exceptIframe) return;
      const src = iframe.src || '';
      if (!iframe.contentWindow) return;
 
      if (src.includes('youtube.com')) {
        iframe.contentWindow.postMessage(
          JSON.stringify({ event: 'command', func: 'pauseVideo', args: [] }),
          '*'
        );
      } else if (src.includes('vimeo.com')) {
        iframe.contentWindow.postMessage(
          JSON.stringify({ method: 'pause' }),
          '*'
        );
      }
    });
  }
 
  function playVideoIn(slide: HTMLElement) {
    // Frenamos todos los demás primero, así nunca suenan dos a la vez
    const iframe = slide.querySelector<HTMLIFrameElement>('.slide-video iframe');
    pauseAllVideos(iframe ?? undefined);
    if (!iframe || !iframe.contentWindow) return;
    const src = iframe.src || '';
 
    if (src.includes('youtube.com')) {
      iframe.contentWindow.postMessage(
        JSON.stringify({ event: 'command', func: 'playVideo', args: [] }),
        '*'
      );
    } else if (src.includes('vimeo.com')) {
      iframe.contentWindow.postMessage(
        JSON.stringify({ method: 'play' }),
        '*'
      );
    }
  }
  // ──────────────────────────────────────────────────────────────────
 
  function visibleSlides(): HTMLElement[] {
    return allSlides.filter(s => {
      if (currentFilter === 'all') return true;
      const tools = s.dataset.tool?.split(',') ?? [];
      const cats  = s.dataset.category?.split(',') ?? [];
      return tools.includes(currentFilter) || cats.includes(currentFilter);
    });
  }
 
  function applyFilter(filter: string) {
    pauseAllVideos();
 
    currentFilter = filter;
    currentIndex  = 0;
    allSlides.forEach(s => {
      const tools = s.dataset.tool?.split(',') ?? [];
      const cats  = s.dataset.category?.split(',') ?? [];
      const match = filter === 'all' || tools.includes(filter) || cats.includes(filter);
      s.dataset.hidden = match ? 'false' : 'true';
    });
 
    buildDots();
    goTo(0, false);
    filterBtns.forEach(btn =>
      btn.classList.toggle('active', btn.dataset.filter === currentFilter)
    );
  }
 
  function buildDots() {
    const dotsContainer = document.getElementById('tu-contenedor-de-dots');
    if (!dotsContainer) return;
  }
 
  function updateDots() {
    dotsEl.querySelectorAll('.works-dot').forEach((d, i) =>
      d.classList.toggle('active', i === currentIndex)
    );
  }
 
  function goTo(index: number, animate = true) {
    pauseAllVideos();
 
    if (window.innerWidth < 768) {
      currentIndex = index;
      updateDots();
      return;
    }
 
    const slides = visibleSlides();
    if (!slides.length) return;
    currentIndex = Math.max(0, Math.min(index, slides.length - 1));
 
    const wrapper = document.getElementById('works-track-wrapper')!;
    const offset = currentIndex * wrapper.offsetWidth;
 
    animate
      ? gsap.to(track, { x: -offset, duration: 0.7, ease: 'power3.inOut' })
      : gsap.set(track, { x: -offset });
 
    updateDots();
    prevBtn.disabled = currentIndex === 0;
    nextBtn.disabled = currentIndex === slides.length - 1;
  }
 
  prevBtn.addEventListener('click', () => goTo(currentIndex - 1));
  nextBtn.addEventListener('click', () => goTo(currentIndex + 1));
 
  // Swipe touch
  let touchStartX = 0;
  const wrapper = document.getElementById('works-track-wrapper')!;
  wrapper.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
  wrapper.addEventListener('touchend', e => {
    const diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) diff > 0 ? goTo(currentIndex + 1) : goTo(currentIndex - 1);
  }, { passive: true });
 
  wrapper.addEventListener('scroll', () => {
    // Frenamos cualquier sonido apenas se detecta movimiento de scroll,
    // para que ningún video siga sonando mientras se cambia de slide.
    pauseAllVideos();
  }, { passive: true });
 
  // ── IntersectionObserver: pausa videos en mobile apenas el slide deja de verse ──
  // (No reproducimos automáticamente al entrar: el usuario decide con el botón play.)
  if (window.innerWidth < 768) {
    const mobileObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          const slide = entry.target as HTMLElement;
          if (entry.isIntersecting && entry.intersectionRatio >= 0.6) {
            // Este slide ocupa la mayoría de la pantalla: actualizamos el índice/dots,
            // pero NO disparamos play automáticamente.
            const idx = visibleSlides().indexOf(slide);
            if (idx !== -1) {
              currentIndex = idx;
              updateDots();
            }
          } else {
            // Cualquier slide que ya no está mayormente visible se calla.
            const iframe = slide.querySelector<HTMLIFrameElement>('.slide-video iframe');
            if (iframe) pauseSingle(iframe);
          }
        });
      },
      { root: wrapper, threshold: [0, 0.6] }
    );
 
    allSlides.forEach(s => mobileObserver.observe(s));
  }
 
  function pauseSingle(iframe: HTMLIFrameElement) {
    const src = iframe.src || '';
    if (!iframe.contentWindow) return;
    if (src.includes('youtube.com')) {
      iframe.contentWindow.postMessage(
        JSON.stringify({ event: 'command', func: 'pauseVideo', args: [] }),
        '*'
      );
    } else if (src.includes('vimeo.com')) {
      iframe.contentWindow.postMessage(JSON.stringify({ method: 'pause' }), '*');
    }
  }
 
  filterBtns.forEach(btn =>
    btn.addEventListener('click', () => applyFilter(btn.dataset.filter ?? 'all'))
  );
 
  window.addEventListener('worksFilter', (e: Event) => {
    const { tool } = (e as CustomEvent<{ tool: string }>).detail;
    const section = document.getElementById('works-section');
    if (section) section.scrollIntoView({ behavior: 'smooth' });
    setTimeout(() => applyFilter(tool), 400);
  });
 
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) pauseAllVideos();
  });

  document.addEventListener('visibilitychange', () => {
  if (document.hidden) pauseAllVideos();
});

// ── Pausa todos los videos cuando el usuario scrollea la PÁGINA ────
// (hacia arriba o abajo) y la sección de works deja de estar a la vista.
// Funciona igual en desktop y mobile.
const worksSection = document.getElementById('works-section');
if (worksSection) {
  const sectionObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) {
          pauseAllVideos();
        }
      });
    },
    { threshold: 0.5 } // se considera "fuera de vista" si queda menos del 50% visible
  );
  sectionObserver.observe(worksSection);
}

applyFilter('all');
 
  applyFilter('all');
</script>