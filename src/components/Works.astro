<style>


/* --- 1. SECCIÓN PRINCIPAL --- */
#works-section {
  position: relative;
  z-index: 1;
  padding: 2rem 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  min-height: 100dvh;
  overflow: hidden; /* antes: hidden */
  background: transparent !important;
}

/* --- 2. CONTENEDOR CON BLUR --- */
#works-track-wrapper {
  background: rgba(00, 00, 00, 0.55); 
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 1.5rem;
  width: 99vw;
  max-width: 1920px;
  overflow: hidden;
  position: relative;
  height: calc(100dvh - 72px - 65px); /* deja lugar a la flecha */
}

@media (min-width: 768px) {
  #works-track-wrapper {
    height: calc(100dvh - 72px - 95px); /* py-10 es más grande en desktop */
  }
}

