/* --- 7. BOTONES Y FILTROS --- */
.works-filter {
  color: rgba(255,255,255,0.25);
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
}
.works-filter:hover { color: rgba(255,255,255,0.6); }
.works-filter.active { color: var(--violet, #7b2fff); }

.works-nav-btn {
  color: rgba(255,255,255,0.25);
  background: none;
  border: none;
  cursor: pointer;
  transition: color 0.2s;
  padding: 0.5rem;
}
.works-nav-btn:hover { color: rgba(255,255,255,0.8); }
.works-nav-btn:disabled { opacity: 0.1; cursor: default; }

.works-dot {
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  transition: background 0.3s, transform 0.3s;
  cursor: pointer;
  border: none;
  padding: 0;
}
.works-dot.active {
  background: var(--violet, #7b2fff);
  transform: scale(1.5);
}
</style>

<script>
  import { gsap } from 'gsap';
 
  // ── 1. VARIABLES Y SELECTORES ──────────────────────────────────────
  let currentFilter = 'all';
  let currentIndex  = 0;
  let touchStartX   = 0;
  let scrollPauseTimeout: ReturnType<typeof setTimeout> | null = null;
 
  const track       = document.getElementById('works-track')!;
  const dotsEl      = document.getElementById('works-dots')!;
  const prevBtn     = document.getElementById('works-prev') as HTMLButtonElement;
  const nextBtn     = document.getElementById('works-next') as HTMLButtonElement;
  const filterBtns  = document.querySelectorAll<HTMLButtonElement>('.works-filter');
  const allSlides   = Array.from(document.querySelectorAll<HTMLElement>('.work-slide'));
  const wrapper     = document.getElementById('works-track-wrapper')!;
  const swipeHint   = document.getElementById('works-swipe-hint');
  const worksSection = document.getElementById('works-section');
 
  // ── 2. FUNCIONES DE CONTROL DE VIDEOS ──────────────────────────────
  function initYtFacades() {
    document.querySelectorAll<HTMLElement>('.yt-facade').forEach((el) => {
      el.addEventListener('click', () => {
        // Forzamos la desaparición del cartel inmediatamente al interactuar con la miniatura
        dismissSwipeHint();

        const id = el.getAttribute('data-video-id');
        if (!id) return;
        el.innerHTML = `<iframe class="yt-frame" style="width:100%;height:100%;border:none;display:block;" src="https://www.youtube.com/embed/${id}?autoplay=1&mute=0&loop=1&playlist=${id}&controls=1&enablejsapi=1&rel=0" frameborder="0" allow="autoplay; fullscreen" allowfullscreen></iframe>`;
        const slide = el.closest<HTMLElement>('.work-slide');
        if (slide) requestAnimationFrame(() => playVideoIn(slide));
      }, { once: true });
    });
  }
 
  function pauseAllVideos(exceptIframe?: HTMLIFrameElement) {
    document.querySelectorAll<HTMLIFrameElement>('.slide-video iframe').forEach(iframe => {
      if (exceptIframe && iframe === exceptIframe) return;
      const src = iframe.src || '';
      if (!iframe.contentWindow) return;
 
      if (src.includes('youtube.com')) {
        iframe.contentWindow.postMessage(
          JSON.stringify({ event: 'command', func: 'pauseVideo', args: [] }),
          '*'
        );
      } else if (src.includes('vimeo.com')) {
        iframe.contentWindow.postMessage(
          JSON.stringify({ method: 'pause' }),
          '*'
        );
      }
    });
  }
 
  function pauseSingle(iframe: HTMLIFrameElement) {
    const src = iframe.src || '';
    if (!iframe.contentWindow) return;
    if (src.includes('youtube.com')) {
      iframe.contentWindow.postMessage(
        JSON.stringify({ event: 'command', func: 'pauseVideo', args: [] }),
        '*'
      );
    } else if (src.includes('vimeo.com')) {
      iframe.contentWindow.postMessage(JSON.stringify({ method: 'pause' }), '*');
    }
  }
 
  function playVideoIn(slide: HTMLElement) {
    const iframe = slide.querySelector<HTMLIFrameElement>('.slide-video iframe');
    pauseAllVideos(iframe ?? undefined);
    if (!iframe || !iframe.contentWindow) return;
    const src = iframe.src || '';
 
    if (src.includes('youtube.com')) {
      iframe.contentWindow.postMessage(
        JSON.stringify({ event: 'command', func: 'playVideo', args: [] }),
        '*'
      );
    } else if (src.includes('vimeo.com')) {
      iframe.contentWindow.postMessage(
        JSON.stringify({ method: 'play' }),
        '*'
      );
    }
  }
 
  // ── 3. FUNCIONES DE FILTROS Y SLIDER ───────────────────────────────
  function visibleSlides(): HTMLElement[] {
    return allSlides.filter(s => {
      if (currentFilter === 'all') return true;
      const tools = s.dataset.tool?.split(',') ?? [];
      const cats  = s.dataset.category?.split(',') ?? [];
      return tools.includes(currentFilter) || cats.includes(currentFilter);
    });
  }
 
  function applyFilter(filter: string) {
    pauseAllVideos();
 
    currentFilter = filter;
    currentIndex  = 0;
    allSlides.forEach(s => {
      const tools = s.dataset.tool?.split(',') ?? [];
      const cats  = s.dataset.category?.split(',') ?? [];
      const match = filter === 'all' || tools.includes(filter) || cats.includes(filter);
      s.dataset.hidden = match ? 'false' : 'true';
    });
 
    goTo(0, false);
    filterBtns.forEach(btn =>
      btn.classList.toggle('active', btn.dataset.filter === currentFilter)
    );
  }
 
  function updateDots() {
    dotsEl.querySelectorAll('.works-dot').forEach((d, i) =>
      d.classList.toggle('active', i === currentIndex)
    );
  }
 
  function goTo(index: number, animate = true) {
    pauseAllVideos();
    const slides = visibleSlides();
    if (!slides.length) return;
    
    // Validamos el índice antes de hacer nada
    const targetIndex = Math.max(0, Math.min(index, slides.length - 1));
    currentIndex = targetIndex;
 
    // ── MODO MOBILE ──
    if (window.innerWidth < 768) {
      const targetSlide = slides[currentIndex];
      if (targetSlide) {
        wrapper.scrollTo({
          left: targetSlide.offsetLeft,
          behavior: animate ? 'smooth' : 'auto'
        });
      }
      updateDots();
      return; // <--- ESTE RETURN ES VITAL PARA QUE NO SIGA LEYENDO ABAJO
    }
 
    // ── MODO DESKTOP (Solo llega acá si width >= 768) ──
    const offset = currentIndex * wrapper.offsetWidth;
    
    if (animate) {
      gsap.to(track, { x: -offset, duration: 0.7, ease: 'power3.inOut' });
    } else {
      gsap.set(track, { x: -offset });
    }
 
    updateDots();
    
    // En vez de desaparecer, solo se deshabilitan visualmente (opacidad)
    prevBtn.disabled = currentIndex === 0;
    nextBtn.disabled = currentIndex === slides.length - 1;
  }
 
  // ── 4. MANEJO DEL CARTEL "DESLIZÁ" (MOBILE HINT) ───────────────────
  let swipeHintDismissed = false;
  function dismissSwipeHint() {
    if (swipeHintDismissed || !swipeHint) return;
    swipeHintDismissed = true;
    gsap.to(swipeHint, {
      opacity: 0,
      duration: 0.4,
      ease: 'power2.out',
      onComplete: () => swipeHint.remove()
    });
  }
 
  // ── 5. LISTENERS DE EVENTOS ────────────────────────────────────────
  
  // Click Flechas
  prevBtn.addEventListener('click', () => goTo(currentIndex - 1));
  nextBtn.addEventListener('click', () => goTo(currentIndex + 1));
 
  // Swipe Touch (Solo Desktop maneja el track manualmente)
  if (window.innerWidth >= 768) {
    wrapper.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
    wrapper.addEventListener('touchend', e => {
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) diff > 0 ? goTo(currentIndex + 1) : goTo(currentIndex - 1);
    }, { passive: true });
  }
 
  // Listener de Scroll UNIFICADO para el Wrapper
  wrapper.addEventListener('scroll', () => {
    // Ocultar hint de mobile en el primer movimiento
    dismissSwipeHint();
 
    // Control de pausa anti-bombardeo de postMessage
    if (scrollPauseTimeout) return;
    pauseAllVideos();
    scrollPauseTimeout = setTimeout(() => { scrollPauseTimeout = null; }, 400);
  }, { passive: true });

  wrapper.addEventListener('click', dismissSwipeHint, { passive: true, once: true });
 
  // Clics en botones de filtro de la página
  filterBtns.forEach(btn =>
    btn.addEventListener('click', () => applyFilter(btn.dataset.filter ?? 'all'))
  );
 
  // Custom Events externos para filtrar o redirigir
  window.addEventListener('worksFilter', (e: Event) => {
    const { tool } = (e as CustomEvent<{ tool: string }>).detail;
    if (worksSection) worksSection.scrollIntoView({ behavior: 'smooth' });
    setTimeout(() => applyFilter(tool), 400);
  });
 
  window.addEventListener('worksGoToAll', () => {
    if (worksSection) worksSection.scrollIntoView({ behavior: 'smooth' });
    setTimeout(() => applyFilter('all'), 400);
  });
 
  // Detener todo si se cambia de pestaña en el navegador
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) pauseAllVideos();
  });
 
  // ── 6. INTERSECTION OBSERVERS ──────────────────────────────────────
  
  // Mobile Observer (Detecta qué slide está activo según scroll nativo)
  if (window.innerWidth < 768) {
    const mobileObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          const slide = entry.target as HTMLElement;
          if (entry.isIntersecting && entry.intersectionRatio >= 0.6) {
            const idx = visibleSlides().indexOf(slide);
            if (idx !== -1) {
              currentIndex = idx;
              updateDots();
            }
          } else {
            const iframe = slide.querySelector<HTMLIFrameElement>('.slide-video iframe');
            if (iframe) pauseSingle(iframe);
          }
        });
      },
      { root: wrapper, threshold: [0, 0.6] }
    );
 
    allSlides.forEach(s => mobileObserver.observe(s));
  }
 
  // Global Section Observer (Pausa videos si el usuario se va de la sección Works)
  if (worksSection) {
    const sectionObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) {
            pauseAllVideos();
          }
        });
      },
      { threshold: 0.5 }
    );
    sectionObserver.observe(worksSection);
  }
 
  // ── 7. EJECUCIÓN INICIAL ───────────────────────────────────────────
  initYtFacades();
  applyFilter('all');
 
  // Animación del cartel "Deslizá" en mobile
  if (window.innerWidth < 768 && swipeHint) {
    gsap.to(swipeHint, { opacity: 1, duration: 0.6, delay: 1, ease: 'power2.out' });
  }
</script>