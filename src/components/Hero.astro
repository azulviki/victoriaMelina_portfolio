---
// src/components/Hero.astro
---

<link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght=700&family=Space+Mono&display=swap" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Michroma&family=Montserrat:ital,wght@0,100..900;1,100..900&family=Open+Sans:ital,wght@0,300..800;1,300..800&family=Roboto+Condensed:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">

<section id="hero-section" class="hero relative min-h-dvh flex items-center overflow-hidden bg-[#080810]">
  
  <canvas id="heroCanvas" class="absolute inset-0 w-full h-full z-0 cursor-crosshair touch-none"></canvas>
  
  <div id="hero-text-container" class="absolute inset-0 z-20 px-6 md:px-16 lg:px-24 w-full flex items-center justify-start opacity-0 pointer-events-none select-none">

    <div class="hero-box relative z-30 flex flex-col gap-0 w-full md:pointer-events-auto">

      <!-- 🔒 BLOQUE SUPERIOR: Inmune a las animaciones de abajo -->
      <div class="hero-top-block w-full md:w-max flex flex-col gap-0">
        <p
          id="hero-eyebrow"
          class="hero-spread hero-tool-item font-mono uppercase text-blue opacity-0 cursor-default text-[0.8rem] md:text-[0.95rem] tracking-[0.3em] md:tracking-[0.4em] mb-4 w-full"
          data-es="Realizadora audiovisual & VJ"
          data-en="Audiovisual Director & VJ"
        >Realizadora audiovisual & VJ</p>

        <!-- H1: Mide exactamente lo mismo tanto en mobile como en desktop -->
        <!-- H1: El contenedor bloquea eventos, solo los span internos con texto los reciben si es necesario -->
<h1
  id="hero-name"
  class="hero-title relative z-40 opacity-0 block mb-2 w-full pointer-events-none"
  style="font-family: 'Montserrat', sans-serif; font-weight: 200; font-size: clamp(2.2rem, 9vw, 6.5rem); line-height: 0.95;"
>
  <!-- 📱 VISTA MOBILE -->
  <span class="row-name-mobile block md:hidden mb-1 pointer-events-none">
    <span>V</span><span>I</span><span>C</span><span>T</span><span>O</span><span>R</span><span>I</span><span>A</span>
  </span>
  <span class="row-name-mobile block md:hidden pointer-events-none">
    <span>M</span><span>E</span><span>L</span><span>I</span><span>N</span><span>A</span>
  </span>

  <!-- 🖥️ VISTA DESKTOP: Añadimos cursor-pointer solo si querés interactuar con el nombre, sino dejalos en pointer-events-none -->
  <span class="hidden md:flex w-full justify-between pointer-events-none">
    <span class="pointer-events-auto cursor-pointer">V</span>
    <span class="pointer-events-auto cursor-pointer">I</span>
    <span class="pointer-events-auto cursor-pointer">C</span>
    <span class="pointer-events-auto cursor-pointer">T</span>
    <span class="pointer-events-auto cursor-pointer">O</span>
    <span class="pointer-events-auto cursor-pointer">R</span>
    <span class="pointer-events-auto cursor-pointer">I</span>
    <span class="pointer-events-auto cursor-pointer">A</span>
  </span>
  <span class="hidden md:flex w-full justify-between pointer-events-none mt-1">
    <span class="pointer-events-auto cursor-pointer">M</span>
    <span class="pointer-events-auto cursor-pointer">E</span>
    <span class="pointer-events-auto cursor-pointer">L</span>
    <span class="pointer-events-auto cursor-pointer">I</span>
    <span class="pointer-events-auto cursor-pointer">N</span>
    <span class="pointer-events-auto cursor-pointer">A</span>
  </span>
</h1>

        <p
          id="hero-alias"
          class="hero-spread font-mono tracking-[0.25em] text-violet/60 opacity-0 cursor-default text-[1.2rem] md:text-[1.5rem] mt-2 mb-4 md:mb-6 w-full"
        >VJ BLUH</p>
      </div>

      <!-- 🌊 BLOQUE INFERIOR: El tagline se expande y afecta SOLO a las tools de abajo -->
      <div class="hero-bottom-block w-full flex flex-col gap-0">
        <p
          id="hero-tagline"
          class="hero-tool-item hero-spread font-mono uppercase opacity-0 cursor-default text-[0.95rem] md:text-[1.2rem] mb-6 w-full"
          data-es="Creo imágenes que se mueven en tiempo real."
          data-en="I make images that move in real time."
        >Creo imágenes que se mueven en tiempo real.</p>

        <!-- Tools: Se desplazan o adaptan según el comportamiento del tagline superior -->
        <div
          id="hero-tools"
          class="flex flex-col gap-3 md:flex-row md:justify-between md:gap-4 w-full font-mono uppercase text-muted opacity-0 text-[0.85rem] md:text-[0.95rem] tracking-[0.1em] mb-8 relative z-40">
          <span class="hero-tool-item cursor-pointer pointer-events-auto">After Effects</span>
          <span class="hero-tool-item cursor-pointer pointer-events-auto">TouchDesigner</span>
          <span class="hero-tool-item cursor-pointer pointer-events-auto">Resolume</span>
        </div>
      </div>

    </div>
  </div>

  <div id="hero-scroll" class="absolute bottom-8 left-6 md:left-16 lg:left-24 z-30 opacity-0 pointer-events-none flex items-center gap-3">
    <div class="w-12 h-px overflow-hidden">
      <div id="scrollLine" class="w-full h-full bg-gradient-to-r from-transparent to-violet origin-left"></div>
    </div>
    <span class="font-mono text-[0.65rem] tracking-[0.15em] uppercase text-muted" data-es="scroll" data-en="scroll">scroll</span>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);
 
  // ─── CANVAS ───────────────────────────────────────────────────────────────
  const canvas = document.getElementById('heroCanvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  let W = 0, H = 0;
 
  interface Particle {
    x: number; y: number;
    vx: number; vy: number;
    size: number; alpha: number;
    hue: number; sat: number; lit: number;
    life: number; maxLife: number;
    drag?: number;
  }
 
  let particles: Particle[] = [];
  function rand(a: number, b: number) { return a + Math.random() * (b - a); }
 
  function makeParticle(): Particle {
    const angle = Math.random() * Math.PI * 2;
    const speed = rand(0.08, 0.45);
    const hue   = Math.random() < 0.6 ? 270 : 190;
    return {
      x: Math.random() * W, y: Math.random() * H,
      vx: Math.cos(angle) * speed, vy: Math.sin(angle) * speed,
      size: rand(5, 12), alpha: rand(0.25, 0.85),
      hue, sat: rand(70, 100), lit: rand(50, 75),
      life: 0, maxLife: rand(200, 700),
    };
  }
 
  function makeBurstParticle(x: number, y: number): Particle {
    const angle = Math.random() * Math.PI * 2;
    const speed = rand(1.5, 5);
    const hue   = Math.random() < 0.5 ? 270 : 190;
    return {
      x, y,
      vx: Math.cos(angle) * speed, vy: Math.sin(angle) * speed,
      size: rand(6, 14), alpha: rand(0.7, 1),
      hue, sat: 100, lit: rand(65, 85),
      life: 0, maxLife: rand(40, 90), drag: 0.92,
    };
  }
 
  function resize() { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }
  function initParticles() {
    const count = Math.min(Math.floor((W * H) / 6000), 180);
    particles = Array.from({ length: count }, makeParticle);
  }
 
  const REPEL_RADIUS = 140, REPEL_FORCE = 8, BURST_COUNT = 18;
  const HOVER_RADIUS = 80,  HOVER_FORCE = 0.4;
  const ATTRACT_RADIUS = 150, ATTRACT_FORCE = 2.5;
  const TRAIL_RATE = 4;
 
  let isDown = false;

  // ★ Flag para bloquear interacción con partículas en mobile una vez revelado el texto
  let canvasInteractionEnabled = true;
 
  function makeTrailParticle(x: number, y: number): Particle {
    const angle = Math.random() * Math.PI * 2;
    const speed = rand(0.2, 1.2);
    const hue   = Math.random() < 0.6 ? 270 : 190;
    return {
      x: x + rand(-8, 8), y: y + rand(-8, 8),
      vx: Math.cos(angle) * speed, vy: Math.sin(angle) * speed,
      size: rand(4, 9), alpha: rand(0.6, 1),
      hue, sat: 100, lit: rand(60, 82),
      life: 0, maxLife: rand(25, 65), drag: 0.94,
    };
  }

  function handleMove(clientX: number, clientY: number) {
    if (!canvasInteractionEnabled) return; // ★
    const rect = canvas.getBoundingClientRect();
    const mx = clientX - rect.left;
    const my = clientY - rect.top;
 
    if (isDown) {
      particles.forEach(p => {
        const dx = mx - p.x, dy = my - p.y;
        const dist = Math.sqrt(dx*dx + dy*dy);
        if (dist < ATTRACT_RADIUS && dist > 0) {
          const force = (1 - dist / ATTRACT_RADIUS) * ATTRACT_FORCE;
          p.vx += (dx/dist) * force;
          p.vy += (dy/dist) * force;
        }
      });
      for (let i = 0; i < TRAIL_RATE; i++) {
        particles.push(makeTrailParticle(mx, my));
      }
    } else {
      particles.forEach(p => {
        const dx = p.x - mx, dy = p.y - my;
        const dist = Math.sqrt(dx*dx + dy*dy);
        if (dist < HOVER_RADIUS && dist > 0) {
          const force = (1 - dist / HOVER_RADIUS) * HOVER_FORCE;
          p.vx += (dx/dist)*force; p.vy += (dy/dist)*force;
        }
      });
    }
  }

  function handlePress(clientX: number, clientY: number) {
    if (!canvasInteractionEnabled) return; // ★
    isDown = true;
  }

  function handleRelease(clientX: number, clientY: number, triggerBurst = false) {
    if (!canvasInteractionEnabled) return; // ★
    isDown = false;
    if (triggerBurst) {
      const rect = canvas.getBoundingClientRect();
      const mx = clientX - rect.left;
      const my = clientY - rect.top;
      particles.forEach(p => {
        const dx = p.x - mx, dy = p.y - my;
        const dist = Math.sqrt(dx*dx + dy*dy);
        if (dist < REPEL_RADIUS && dist > 0) {
          const force = (1 - dist / REPEL_RADIUS) * REPEL_FORCE;
          p.vx += (dx/dist)*force; p.vy += (dy/dist)*force;
          p.life = 0; p.maxLife = rand(200, 500);
        }
      });
      particles.push(...Array.from({ length: BURST_COUNT }, () => makeBurstParticle(mx, my)));
    }
  }
 
  // Listeners Mouse
  canvas.addEventListener('mousedown', (e) => handlePress(e.clientX, e.clientY));
  canvas.addEventListener('mouseup', (e) => handleRelease(e.clientX, e.clientY, true));
  canvas.addEventListener('mouseleave', () => handleRelease(0, 0, false));
  canvas.addEventListener('mousemove', (e) => handleMove(e.clientX, e.clientY));

  // Listeners Touch
  canvas.addEventListener('touchstart', (e) => {
    const touch = e.touches[0];
    handlePress(touch.clientX, touch.clientY);
  }, { passive: true });

  canvas.addEventListener('touchmove', (e) => {
    const touch = e.touches[0];
    handleMove(touch.clientX, touch.clientY);
  }, { passive: true });

  canvas.addEventListener('touchend', (e) => {
    if (e.changedTouches.length > 0) {
      const touch = e.changedTouches[0];
      handleRelease(touch.clientX, touch.clientY, true);
    }
  }, { passive: true });
 
  function drawFrame() {
    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = 'rgba(8,8,16,0.2)';
    ctx.fillRect(0, 0, W, H);
 
    for (let i = particles.length - 1; i >= 0; i--) {
      const p = particles[i];
      p.life++;
      if (p.drag !== undefined) { p.vx *= p.drag; p.vy *= p.drag; }
      p.x += p.vx; p.y += p.vy;
      const progress = p.life / p.maxLife;
      const fade = progress < 0.1 ? progress/0.1 : progress > 0.8 ? (1-progress)/0.2 : 1;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
      ctx.fillStyle = `hsla(${p.hue},${p.sat}%,${p.lit}%,${p.alpha * fade})`;
      ctx.fill();
      if (p.life >= p.maxLife) {
        if (p.drag !== undefined) particles.splice(i, 1);
        else particles[i] = makeParticle();
      } else if (p.drag === undefined && (p.x < -10 || p.x > W+10 || p.y < -10 || p.y > H+10)) {
        particles[i] = makeParticle();
      }
    }
 
    const ambient = particles.filter(p => p.drag === undefined);
    for (let i = 0; i < ambient.length; i++) {
      for (let j = i + 1; j < ambient.length; j++) {
        const dx = ambient[i].x - ambient[j].x, dy = ambient[i].y - ambient[j].y;
        const dist = Math.sqrt(dx*dx + dy*dy);
        if (dist < 100) {
          ctx.beginPath();
          ctx.moveTo(ambient[i].x, ambient[i].y);
          ctx.lineTo(ambient[j].x, ambient[j].y);
          ctx.strokeStyle = `rgba(123,47,255,${0.08*(1-dist/100)})`;
          ctx.lineWidth = 0.6; ctx.stroke();
        }
      }
    }
    requestAnimationFrame(drawFrame);
  }
 
  function startCanvas() { resize(); initParticles(); drawFrame(); }
  window.addEventListener('resize', () => { resize(); initParticles(); }, { passive: true });
  startCanvas();
 
  // ─── ANIMACIÓN DE ENTRADA ──────────────────────────────────────────────────
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isDesktop = window.innerWidth >= 768;
  
  if (prefersReduced) {
    gsap.set(['#hero-text-container', '#hero-eyebrow','#hero-name','#hero-alias','#hero-tagline','#hero-tools','#hero-scroll'], { opacity: 1 });
  } else if (isDesktop) {
    gsap.set('#hero-text-container', { opacity: 1 });

    const tl = gsap.timeline({ delay: 0.2 });
    tl.fromTo('#hero-eyebrow',  { opacity: 0, x: -16 }, { opacity: 1, x: 0, duration: 0.5, ease: 'power2.out' })
      .fromTo('#hero-name',     { opacity: 0, x: -40 }, { opacity: 1, x: 0, duration: 0.9, ease: 'power3.out' }, '-=0.1')
      .fromTo('#hero-alias',    { opacity: 0, x: -16 }, { opacity: 1, x: 0, duration: 0.5, ease: 'power2.out' }, '-=0.4')
      .fromTo('#hero-tagline',  { opacity: 0, x: -16 }, { opacity: 1, x: 0, duration: 0.5, ease: 'power2.out' }, '-=0.2')
      .fromTo('#hero-tools',    { opacity: 0 },          { opacity: 1, duration: 0.5, ease: 'power1.out' },       '-=0.1')
      .fromTo('#hero-scroll',   { opacity: 0 },          { opacity: 1, duration: 0.4 },                           '-=0.1');
 
    gsap.fromTo('#scrollLine',
      { scaleX: 0, transformOrigin: 'left' },
      { scaleX: 1, duration: 1, ease: 'power1.inOut', repeat: -1, yoyo: true, delay: 1.5 }
    );
  } else {
    // ★ MOBILE: el texto empieza invisible, solo partículas
    // El contenedor de texto queda oculto; los hijos no necesitan opacity propia
    gsap.set('#hero-text-container', { opacity: 0, pointerEvents: 'none' });
    gsap.set(['#hero-eyebrow', '#hero-name', '#hero-alias', '#hero-tagline', '#hero-tools'], { opacity: 1, y: 0 });

    // ★ Indicador de scroll: aparece rápido para invitar a tocarlo
    gsap.fromTo('#hero-scroll',
      { opacity: 0 },
      { opacity: 1, duration: 0.6, delay: 0.8 }
    );
    gsap.set('#hero-scroll', { pointerEvents: 'auto' });

    gsap.fromTo('#scrollLine',
      { scaleX: 0, transformOrigin: 'left' },
      { scaleX: 1, duration: 1, ease: 'power1.inOut', repeat: -1, yoyo: true }
    );

    // ★ Al tocar el indicador de scroll → reveal del texto y bloqueo del canvas
    let heroRevealed = false;
    const heroScrollBtn = document.getElementById('hero-scroll')!;

    function revealHeroMobile() {
      if (heroRevealed) return;
      heroRevealed = true;

      // Desactiva interacción con partículas
      canvasInteractionEnabled = false;
      canvas.style.pointerEvents = 'none';

      // Oculta el botón de scroll
      gsap.to('#hero-scroll', { opacity: 0, duration: 0.3 });//

      // Revela el texto subiendo desde abajo
      gsap.set('#hero-text-container', { opacity: 1, pointerEvents: 'auto' });
      const tl = gsap.timeline();
      tl.fromTo('#hero-eyebrow',
          { opacity: 0, y: 24 }, { opacity: 1, y: 0, duration: 0.45, ease: 'power2.out' })
        .fromTo('#hero-name',
          { opacity: 0, y: 40 }, { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' }, '-=0.1')
        .fromTo('#hero-alias',
          { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' }, '-=0.3')
        .fromTo('#hero-tagline',
          { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' }, '-=0.2')
        .fromTo('#hero-tools',
          { opacity: 0 },        { opacity: 1, duration: 0.4, ease: 'power1.out' },        '-=0.1');
    }

    // ★ Se dispara al pasar el dedo por encima (touchmove sobre el documento)
document.addEventListener('touchmove', (e) => {
  if (heroRevealed) return;
  const touch = e.touches[0];
  const rect = heroScrollBtn.getBoundingClientRect();
  // Área de hit generosa: 48px extra arriba/abajo para facilitar el gesto
  if (
    touch.clientX >= rect.left - 24 &&
    touch.clientX <= rect.right + 24 &&
    touch.clientY >= rect.top - 48 &&
    touch.clientY <= rect.bottom + 48
  ) {
    revealHeroMobile();
  }
}, { passive: true });

// Fallback click para simuladores
heroScrollBtn.addEventListener('click', revealHeroMobile);
  }

  // ─── SCROLLTRIGGER MATCHMEDIA ─────────────────────────────────────────────
  ScrollTrigger.matchMedia({
    // ★ MOBILE: ya no maneja la aparición del texto (eso lo hace el tap),
    //   solo se ocupa de hacer fade-out del hero cuando el usuario sigue scrolleando
    "(max-width: 767px)": function() {
      ScrollTrigger.create({
        trigger: '#hero-section',
        start: 'top top',
        end: '+=60%',
        scrub: true,
        onUpdate(self) {
          // Fade out del hero completo al hacer scroll hacia abajo
          const opacity = 1 - self.progress;
          gsap.set(['#hero-text-container', '#heroCanvas'], { opacity });
        }
      });
    },

    // DESKTOP: sin cambios
    "(min-width: 768px)": function() {
      gsap.set('#hero-text-container', { opacity: 1 });
      gsap.set('#hero-scroll', { opacity: 1 });
    }
  });
 
  // ─── LANG SYNC ────────────────────────────────────────────────────────────
  function applyLangToHero(lang: 'es' | 'en') {
    document.querySelectorAll<HTMLElement>('#hero-eyebrow, #hero-tagline, #hero-scroll span').forEach(el => {
      const val = el.dataset[lang];
      if (val) el.textContent = val;
    });
  }
  const saved = (localStorage.getItem('lang') as 'es' | 'en' | null) ?? 'es';
  applyLangToHero(saved);
  window.addEventListener('langchange', (e: Event) => {
    const { lang } = (e as CustomEvent<{ lang: 'es' | 'en' }>).detail;
    applyLangToHero(lang);
  });
</script>