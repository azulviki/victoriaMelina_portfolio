---
// src/components/Contacto.astro
//
// Esta sección vive una sola vez en el documento.
// El botón "Contacto" del Hero genera un scroll suave nativo hasta acá.
// Reemplazamos el formulario por accesos directos y limpios a canales de comunicación.
import ScrollToTopArrow from './ScrollToTopArrow.astro';
---

<section id="contacto-section" class="contacto relative w-full overflow-hidden flex flex-col items-center" style="min-height: calc(100dvh - 72px);">

  <div class="relative z-10 w-full px-6 md:px-16 lg:px-24 py-16 md:py-24 flex justify-center flex-1">

    <div id="contacto-box" class="contacto-box reveal-up w-full max-w-[800px] self-center">

      <p class="font-mono uppercase text-blue text-[0.9rem] text-center md:text-[1.10rem] tracking-[0.4em] mb-4">
        Conexión
      </p>

      <h2  class="contacto-title mb-6 text-center" style="font-family: 'Montserrat', sans-serif; font-weight: 100; font-size: clamp(0.05rem, 3vw, 2rem); line-height: 1.1;">
       [ Si querés, charlamos ]
      </h2>

      <p class="contacto-description font-mono text-[1.8remrem] md:text-[1.5rem] text-center leading-relaxed text-muted/80 mb-10">
        La vía la elegís vos.
      </p>

      <div class="contacto-links flex items-center justify-center gap-8 w-full pointer-events-auto relative z-50">
        
        <a 
          href="https://wa.me/+541156231164" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="contacto-link-btn"
          aria-label="WhatsApp"
        >
          <svg class="link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
          </svg>
        </a>

        <!-- Email (Link Web a Gmail — Evita los bloqueos de protocolos del sistema operativo) -->
        <a 
          href="https://mail.google.com/mail/?view=cm&fs=1&to=azulesvictoria@gmail.com" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="contacto-link-btn"
          aria-label="Email"
        >
          <svg class="link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
        </a>

        <a 
          href="https://instagram.com/hiroshima.espiritual" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="contacto-link-btn"
          aria-label="Instagram"
        >
          <svg class="link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </a>

      </div>
    </div>
  </div>

  <ScrollToTopArrow />
</section>

<style>
  .contacto-title {
    color: #fff;
  }

  /* Glass box — Clonado exacto del lenguaje visual de #works-track-wrapper */
.contacto-box {
  background: rgba(0, 0, 0, 0.55);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 1.5rem;
  padding: 2.5rem 2rem;
  box-sizing: border-box;
}

@media (min-width: 768px) {
  .contacto-box {
    padding: 8rem 5rem;
    max-width: 800px; /* antes era 640px, vía el contenedor padre */
  }
}

/* Botones de íconos: circulares, sin texto ni flecha */
.contacto-link-btn {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 64px;
  height: 64px;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: 50%;
  color: #f0f0f8;
  text-decoration: none;
  transition: border-color 0.25s ease, background 0.25s ease, transform 0.2s ease;
  box-sizing: border-box;
  outline: none;
  cursor: pointer;
  -webkit-appearance: none;
  appearance: none;
  -webkit-tap-highlight-color: transparent; /* saca el flash azul nativo en mobile */
}

.link-icon {
  width: 28px;   
  height: 28px;  
  opacity: 0.85;
  transition: transform 0.25s ease, color 0.25s ease;
}

/* Hover SOLO en dispositivos con puntero real (mouse/trackpad) */
@media (hover: hover) and (pointer: fine) {
  .contacto-link-btn:hover {
    border-color: var(--violet, #7b2fff);
    background: rgba(255, 255, 255, 0.06);
    transform: translateY(-3px);
  }

  .contacto-link-btn:hover .link-icon {
    color: var(--violet, #7b2fff);
    opacity: 1;
  }

  .contacto-link-btn:active {
    border-color: var(--violet, #7b2fff);
    background: rgba(255, 255, 255, 0.06);
    transform: translateY(-1px) scale(0.97);
  }

  .contacto-link-btn:active .link-icon {
    color: var(--violet, #7b2fff);
    opacity: 1;
  }
}

/* Estado "presionado" para touch, controlado por JS (solo dura mientras hay contacto físico) */
.contacto-link-btn.is-pressed {
  border-color: var(--violet, #7b2fff);
  background: rgba(255, 255, 255, 0.06);
  transform: translateY(-1px) scale(0.97);
}

.contacto-link-btn.is-pressed .link-icon {
  color: var(--violet, #7b2fff);
  opacity: 1;
}

  /* Reveal-up al hacer scroll (mismo comportamiento que el resto de tu web) */
  .reveal-up {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal-up.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal-up {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  // Lógica idéntica de Reveal-on-scroll sin interferencias
  const targets = document.querySelectorAll('#contacto-section .reveal-up');
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;


  // Feedback táctil en mobile: violeta SOLO mientras el dedo sigue tocando el ícono.
 // Se limpia con touchend Y touchcancel para evitar que quede "pegado".
  
  const linkBtns = document.querySelectorAll<HTMLElement>('.contacto-link-btn');
  linkBtns.forEach(btn => {
  btn.addEventListener('touchstart', () => {
    btn.classList.add('is-pressed');
  }, { passive: true });

  const release = () => btn.classList.remove('is-pressed');

  btn.addEventListener('touchend', release, { passive: true });
  btn.addEventListener('touchcancel', release, { passive: true });
});

  if (prefersReduced) {
    targets.forEach(el => el.classList.add('visible'));
  } else {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            el.classList.add('visible');
            observer.unobserve(el);
          }
        });
      },
      { threshold: 0.2 }
    );
    targets.forEach(el => observer.observe(el));
  }
</script>