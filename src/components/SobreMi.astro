---
// src/components/SobreMi.astro
import ScrollToTopArrow from './ScrollToTopArrow.astro';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const videoSrc = `${base}videos/sobremi.mp4`;
const posterSrc = `${base}images/sobremi-poster.jpg`;
---

<section id="sobremi-section" class="sobremi relative w-full overflow-hidden flex items-center" style="min-height: calc(100dvh - 72px);">

  <div class="relative z-10 w-full px-6 md:px-16 lg:px-24 py-16 md:py-24">
    <div class="sobremi-grid w-full flex flex-col md:flex-row md:items-center gap-10 md:gap-16">

      <!-- TEXTO -->
      <div class="sobremi-text w-full md:w-1/2 flex flex-col gap-6 reveal-up">
        <p
          class="font-mono uppercase text-blue text-[0.8rem] md:text-[0.95rem] tracking-[0.4em]"
        >Sobre mí</p>

        <h2
          class="sobremi-title"
          style="font-family: 'Montserrat', sans-serif; font-weight: 200; font-size: clamp(1.8rem, 4.5vw, 3rem); line-height: 1.1;"
        >
          [ Observo y escucho ]
        </h2>

        <div class="sobremi-body font-mono text-[0.95rem] md:text-[1rem] leading-relaxed text-gray-500 flex flex-col gap-4">
          <p>
            [ Realizadora multimedial especializada en arte digital, animación y performance audiovisual en tiempo real. 
            Mi trabajo abarca desde la producción de música original hasta el diseño de visuales reactivas y la operación en vivo. ]
          </p>
          <p>
            [ A través del diálogo entre el sonido y la imagen, construyo experiencias diseñadas tanto para el entorno digital como para el espacio vivo de un show. ]
          </p>
        </div>
      </div>

      <!-- VIDEO LOOP -->
      <div class="sobremi-media relative z-10 w-full md:w-1/2 flex md:justify-center">
        <div class="sobremi-video-frame">
          <video
            class="sobremi-video"
            autoplay
            muted
            loop
            playsinline
            preload="auto"
            poster="/images/sobremi-poster.jpg"
            onerror="this.insertAdjacentHTML('afterend', '<p style=\'color:red;font-size:10px;position:absolute;top:0;left:0;background:#fff;z-index:99;padding:4px\'>VIDEO ERROR: ' + (this.error ? this.error.code : 'unknown') + '</p>')"
          >
            <source src={videoSrc} type="video/mp4" />
          </video>
        </div>
      </div>

    </div>

    <ScrollToTopArrow />
  </div>
</section>

<style>
  .sobremi-title {
    color: var(--color-brand-dark);
  }

  .sobremi-video-frame {
  position: relative;
  width: 55%;
  max-width: 220px;
  margin: 0 auto;
  aspect-ratio: 3 / 2;
  border-radius: 1rem;
  overflow: hidden;
  background: #000;
  border: 1px solid var(--border);
}

@media (min-width: 768px) {
  .sobremi-video-frame {
    width: 100%;
    max-width: 260px;
    aspect-ratio: 3 / 4;
  }
}

  .sobremi-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (min-width: 768px) {
    .sobremi-video-frame {
      width: 100%;
      max-width: 260px;
      aspect-ratio: 3 / 4;
    }
  }

  /* Reveal al hacer scroll, mismo lenguaje de movimiento que el resto del sitio */
  .reveal-up {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal-up.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal-up {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  // Reveal-on-scroll simple para los bloques de esta sección
  const targets = document.querySelectorAll('#sobremi-section .reveal-up');

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (prefersReduced) {
    targets.forEach(el => el.classList.add('visible'));
  } else {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry, i) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            setTimeout(() => el.classList.add('visible'), i * 120);
            observer.unobserve(el);
          }
        });
      },
      { threshold: 0.2 }
    );

    targets.forEach(el => observer.observe(el));
  }

  // ─── FIX AUTOPLAY EN MOBILE (Safari/iOS) ─────────────────────────────────
  const sobremiVideo = document.querySelector('#sobremi-section .sobremi-video') as HTMLVideoElement | null;

  if (sobremiVideo) {
    const tryPlay = () => sobremiVideo.play().catch(() => {});
    tryPlay();
    sobremiVideo.addEventListener('loadeddata', tryPlay);
    sobremiVideo.addEventListener('canplay', tryPlay);
    document.addEventListener('touchstart', tryPlay, { once: true, passive: true });
  }

  // Nota: las partículas de fondo de esta sección ahora las provee el
  // canvas global definido en Base.astro (#globalParticlesCanvas).
  // Ya no hay un canvas local propio acá.
</script>