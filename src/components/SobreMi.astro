---
// src/components/SobreMi.astro
---

<section id="sobremi-section" class="sobremi relative w-full bg-[#080810] overflow-hidden flex items-center" style="min-height: calc(100dvh - 72px);">

  <canvas id="sobremiCanvas" class="absolute inset-0 w-full h-full z-0 pointer-events-none" aria-hidden="true"></canvas>

  <div class="relative z-10 w-full px-6 md:px-16 lg:px-24 py-16 md:py-24">
    <div class="sobremi-grid w-full flex flex-col md:flex-row md:items-center gap-10 md:gap-16">

      <!-- TEXTO -->
      <div class="sobremi-text w-full md:w-1/2 flex flex-col gap-6 reveal-up">
        <p
          class="font-mono uppercase text-blue text-[0.8rem] md:text-[0.95rem] tracking-[0.4em]"
        >Sobre mí</p>

        <h2
          class="sobremi-title"
          style="font-family: 'Montserrat', sans-serif; font-weight: 200; font-size: clamp(1.8rem, 4.5vw, 3rem); line-height: 1.1;"
        >
          [ Placeholder: título o frase de apertura sobre Victoria ]
        </h2>

        <div class="sobremi-body font-mono text-[0.95rem] md:text-[1rem] leading-relaxed text-muted/80 flex flex-col gap-4">
          <p>
            [ Placeholder: párrafo 1 de la bio. Acá va la historia de Victoria como
            realizadora multimedial — de dónde viene su lenguaje visual, qué la
            mueve a crear atmósferas audiovisuales. ]
          </p>
          <p>
            [ Placeholder: párrafo 2. Trayectoria, formación, proyectos
            destacados o la forma en que combina herramientas como
            TouchDesigner, Ableton Live y Resolume en vivo. ]
          </p>
        </div>
      </div>

      <!-- VIDEO LOOP -->
      <div class="sobremi-media relative z-10 w-full md:w-1/2 flex md:justify-center">
        <div class="sobremi-video-frame">
          <video
            class="sobremi-video"
            autoplay
            muted
            loop
            playsinline
            preload="auto"
            poster="/images/sobremi-poster.jpg"
            onerror="this.insertAdjacentHTML('afterend', '<p style=\'color:red;font-size:10px;position:absolute;top:0;left:0;background:#fff;z-index:99;padding:4px\'>VIDEO ERROR: ' + (this.error ? this.error.code : 'unknown') + '</p>')"
          >
            <source src="/videos/sobremi.mp4" type="video/mp4" />
          </video>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .sobremi-title {
    color: var(--color-brand-dark);
  }

  .sobremi-video-frame {
    position: relative;
    width: 70%;
    max-width: 320px;
    margin: 0 auto;
    aspect-ratio: 4 / 5;
    border-radius: 1rem;
    overflow: hidden;
    background: #000;
    border: 1px solid var(--border);
  }

  .sobremi-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (min-width: 768px) {
    .sobremi-video-frame {
      width: 100%;
      max-width: 260px;
      aspect-ratio: 3 / 4;
    }
  }

  /* Reveal al hacer scroll, mismo lenguaje de movimiento que el resto del sitio */
  .reveal-up {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal-up.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal-up {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  // Reveal-on-scroll simple para los bloques de esta sección
  const targets = document.querySelectorAll('#sobremi-section .reveal-up');

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (prefersReduced) {
    targets.forEach(el => el.classList.add('visible'));
  } else {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry, i) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            setTimeout(() => el.classList.add('visible'), i * 120);
            observer.unobserve(el);
          }
        });
      },
      { threshold: 0.2 }
    );

    targets.forEach(el => observer.observe(el));
  }

// ─── FIX AUTOPLAY EN MOBILE (Safari/iOS) ─────────────────────────────────
  const sobremiVideo = document.querySelector('#sobremi-section .sobremi-video') as HTMLVideoElement | null;

  if (sobremiVideo) {
    const tryPlay = () => sobremiVideo.play().catch(() => {});
    tryPlay();
    sobremiVideo.addEventListener('loadeddata', tryPlay);
    sobremiVideo.addEventListener('canplay', tryPlay);
    document.addEventListener('touchstart', tryPlay, { once: true, passive: true });
  }

  // ─── PARTÍCULAS AMBIENTALES DE FONDO ─────────────────────────────────────
  // Versión liviana y sin interacción del canvas del Hero: solo atmósfera,
  // con opacidad baja para no competir con el texto ni el video.
  const sobremiCanvas = document.getElementById('sobremiCanvas') as HTMLCanvasElement | null;

  if (sobremiCanvas && !prefersReduced) {
    const ctx = sobremiCanvas.getContext('2d')!;
    const section = document.getElementById('sobremi-section')!;
    let W = 0, H = 0;
    let raf = 0;
    let running = false;

    interface AmbientParticle {
      x: number; y: number;
      vx: number; vy: number;
      size: number; alpha: number;
      hue: number; sat: number; lit: number;
    }

    let particles: AmbientParticle[] = [];
    const rand = (a: number, b: number) => a + Math.random() * (b - a);

    function makeParticle(): AmbientParticle {
      const angle = Math.random() * Math.PI * 2;
      const speed = rand(0.08, 0.45);
      const hue = Math.random() < 0.6 ? 270 : 190;
      return {
        x: Math.random() * W,
        y: Math.random() * H,
        vx: Math.cos(angle) * speed,
        vy: Math.sin(angle) * speed,
        size: rand(4, 10),
        alpha: rand(0.15, 0.35),
        hue, sat: rand(70, 100), lit: rand(50, 75),
      };
    }

    function resize() {
      W = sobremiCanvas.width = section.offsetWidth;
      H = sobremiCanvas.height = section.offsetHeight;
    }

    function initParticles() {
      const isMobile = window.innerWidth < 768;
      const divisor = isMobile ? 16000 : 11000;
      const maxCount = isMobile ? 35 : 70;
      const count = Math.min(Math.floor((W * H) / divisor), maxCount);
      particles = Array.from({ length: count }, makeParticle);
    }

    function drawFrame() {
      ctx.clearRect(0, 0, W, H);
      particles.forEach(p => {
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < -10) p.x = W + 10;
        if (p.x > W + 10) p.x = -10;
        if (p.y < -10) p.y = H + 10;
        if (p.y > H + 10) p.y = -10;

        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = `hsla(${p.hue},${p.sat}%,${p.lit}%,${p.alpha})`;
        ctx.fill();
      });
      raf = requestAnimationFrame(drawFrame);
    }

    function start() {
      if (running) return;
      running = true;
      drawFrame();
    }

    function stop() {
      running = false;
      cancelAnimationFrame(raf);
    }

    resize();
    initParticles();

    window.addEventListener('resize', () => { resize(); initParticles(); }, { passive: true });

    // Solo animamos mientras la sección está en pantalla: ahorra batería/CPU
    const sectionObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          entry.isIntersecting ? start() : stop();
        });
      },
      { threshold: 0.05 }
    );
    sectionObserver.observe(section);
  }
</script>