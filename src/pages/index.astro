---
// src/pages/index.astro
import Base from '@/layouts/Base.astro';
import Nav from '@/components/Nav.astro';
import Hero from '@/components/Hero.astro';
import Works from '@/components/Works.astro';
import SobreMi from '@/components/SobreMi.astro';
import Contacto from '@/components/Contacto.astro';
import ContactoModal from '@/components/ContactoModal.astro';
import Footer from '@/components/Footer.astro';
---

<Base>
 <! <Nav currentPath="/" /-->

  <main>
    <Hero />
    <Works />
    <SobreMi />
    <Contacto />
    <ContactoModal />
    

    <!-- Sections — próximos buckets -->
    <section id="work"    class="py-32 border-t border-white/[0.08]"><div class="w-full max-w-[1200px] mx-auto px-6"><p class="section-eyebrow">Proyectos — próximo bucket</p></div></section>
    <section id="sobremi"   class="py-32 border-t border-white/[0.08]"><div class="w-full max-w-[1200px] mx-auto px-6"><p class="section-eyebrow">Sobre mí — próximo bucket</p></div></section>
    <section id="cv"      class="py-32 border-t border-white/[0.08]"><div class="w-full max-w-[1200px] mx-auto px-6"><p class="section-eyebrow">CV — próximo bucket</p></div></section>
    <section id="contact" class="py-32 border-t border-white/[0.08]"><div class="w-full max-w-[1200px] mx-auto px-6"><p class="section-eyebrow">Contacto — próximo bucket</p></div></section>
  </main>

  <Footer />
</Base>