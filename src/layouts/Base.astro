---
// src/layouts/Base.astro
// Base HTML layout — wraps every page
// Props: title, description
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Victoria Melina — VJ Bluh',
  description = 'Realizadora multimedial - After Effects | TouchDesigner | Resolume',
} = Astro.props;
---

<!doctype html>
<html lang="es" id="root-html">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Open Graph (WhatsApp, Facebook, LinkedIn) -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://victoriamelina.art/" /> 
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://victoriamelina.art/images/preview-whatsapp.jpg" /> 

    <!-- Twitter/X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://victoriamelina.art/images/preview-whatsapp.jpg" />
    <!-- La línea de arriba genera automáticamente la URL absoluta (https://victoriamelina.art/preview-whatsapp.jpg) usando el 'site' que configuraste en tu astro.config.mjs -->

    
   

    <!-- Favicon placeholder -->
    <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png">
<link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16x16.png">
<link rel="manifest" href="/images/site.webmanifest">

    <style>
      #globalParticlesCanvas {
        position: fixed;
        inset: 0;
        width: 100vw;
        height: 100vh;
        z-index: 0;
        pointer-events: none;
        background: #000;
      }
    </style>
  </head>

    <script is:inline>
      const savedLang = localStorage.getItem('lang') || 'es';
      document.documentElement.lang = savedLang;
    </script>
  </head>
  <body class="bg-black text-[#f0f0f8] min-h-screen antialiased selection:bg-[#7b2fff]/30 selection:text-white">
    <canvas id="globalParticlesCanvas" aria-hidden="true"></canvas>
    <slot />

    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      gsap.registerPlugin(ScrollTrigger);

      const canvas = document.getElementById('globalParticlesCanvas') as HTMLCanvasElement;
      const ctx = canvas.getContext('2d')!;
      let W = 0, H = 0;

      interface Particle {
        x: number; y: number;
        vx: number; vy: number;
        size: number; alpha: number;
        hue: number; sat: number; lit: number;
        life: number; maxLife: number;
        drag?: number;
      }

      let particles: Particle[] = [];
      const rand = (a: number, b: number) => a + Math.random() * (b - a);

      function makeParticle(): Particle {
        const angle = Math.random() * Math.PI * 2;
        const speed = rand(0.08, 0.45);
        const hue = Math.random() < 0.6 ? 270 : 190;
        return {
          x: Math.random() * W, y: Math.random() * H,
          vx: Math.cos(angle) * speed, vy: Math.sin(angle) * speed,
          size: rand(4, 10),
          alpha: rand(0.25, 0.85),
          hue, sat: rand(70, 100), lit: rand(50, 75),
          life: 0, maxLife: rand(200, 700),
        };
      }

      function makeBurstParticle(x: number, y: number): Particle {
        const angle = Math.random() * Math.PI * 2;
        const speed = rand(1.5, 5);
        const hue = Math.random() < 0.5 ? 270 : 190;
        return {
          x, y,
          vx: Math.cos(angle) * speed, vy: Math.sin(angle) * speed,
          size: rand(5, 12),
          alpha: rand(0.7, 1),
          hue, sat: 100, lit: rand(65, 85),
          life: 0, maxLife: rand(40, 90), drag: 0.92,
        };
      }

      function makeTrailParticle(x: number, y: number): Particle {
        const angle = Math.random() * Math.PI * 2;
        const speed = rand(0.15, 0.6);
        const hue = Math.random() < 0.6 ? 270 : 190;
        return {
          x: x + rand(-8, 8), y: y + rand(-8, 8),
          vx: Math.cos(angle) * speed, vy: Math.sin(angle) * speed,
          size: rand(3, 7), alpha: rand(0.6, 1),
          hue, sat: 100, lit: rand(60, 82),
          life: 0, maxLife: rand(25, 65), drag: 0.94,
        };
      }

      function resize() {
        W = canvas.width = window.innerWidth;
        H = canvas.height = window.innerHeight;
      }

      function initParticles() {
        const isMobile = window.innerWidth < 768;
        const divisor = isMobile ? 9500 : 6000;
        const maxCount = isMobile ? 85 : 180;
        const count = Math.min(Math.floor((W * H) / divisor), maxCount);
        particles = Array.from({ length: count }, makeParticle);
      }

      const REPEL_RADIUS = 140, REPEL_FORCE = 8, BURST_COUNT = 15;
      const HOVER_RADIUS = 80, HOVER_FORCE = 0.4;
      const ATTRACT_RADIUS = 150, ATTRACT_FORCE = 2.5;
      const TRAIL_RATE = 3;

      let isDown = false;
      // La interacción (mouse/touch) solo se habilita mientras el Hero
      // está visible en pantalla. Fuera del Hero, las partículas siguen
      // flotando solas, sin reaccionar al cursor.
      let interactionEnabled = true;
      // ─── ZONA DE EXCLUSIÓN: el texto del Hero no debe "atraer" partículas ───
// Solo aplica en desktop (en mobile el texto tapa la pantalla y la
// interacción ya se corta por completo al revelarse, ver heroTextRevealed).
let heroBoxRect: DOMRect | null = null;

function updateHeroBoxRect() {
  if (window.innerWidth < 768) {
    heroBoxRect = null;
    return;
  }
  const heroBox = document.querySelector('.hero-box');
  heroBoxRect = heroBox ? heroBox.getBoundingClientRect() : null;
}

function isInsideHeroBox(x: number, y: number) {
  if (!heroBoxRect) return false;
  return (
    x >= heroBoxRect.left && x <= heroBoxRect.right &&
    y >= heroBoxRect.top && y <= heroBoxRect.bottom
  );
}

      // En mobile, el texto del hero no aparece por scroll sino por un
      // tap en la scroll-zone (ver Hero.astro). Cuando eso pasa, forzamos
      // que las partículas bajen de opacidad y dejen de ser interactivas
      // PARA SIEMPRE en esa sesión de página: aunque el usuario vuelva a
      // subir al hero con el scroll, las partículas no recuperan ni la
      // opacidad ni la interactividad. Solo un refresh de página reinicia
      // este estado.
      let heroTextRevealedMobile = false;
      const MOBILE_TEXT_OPACITY = 0.25;

      window.addEventListener('heroTextRevealed', () => {
        if (heroTextRevealedMobile) return; // ya disparado, no repetir
        heroTextRevealedMobile = true;
        gsap.to(canvas, { opacity: MOBILE_TEXT_OPACITY, duration: 0.4, ease: 'power1.out' });
        interactionEnabled = false;
      });

     function handleMove(clientX: number, clientY: number) {
  if (!interactionEnabled) return;
  if (isInsideHeroBox(clientX, clientY)) return; // el mouse está sobre el texto: no reacciona
  const mx = clientX;
  const my = clientY;

        if (isDown) {
          particles.forEach(p => {
            const dx = mx - p.x, dy = my - p.y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < ATTRACT_RADIUS && dist > 0) {
              const force = (1 - dist / ATTRACT_RADIUS) * ATTRACT_FORCE;
              p.vx += (dx / dist) * force;
              p.vy += (dy / dist) * force;
            }
          });
          for (let i = 0; i < TRAIL_RATE; i++) {
            particles.push(makeTrailParticle(mx, my));
          }
        } else {
          particles.forEach(p => {
            const dx = p.x - mx, dy = p.y - my;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < HOVER_RADIUS && dist > 0) {
              const force = (1 - dist / HOVER_RADIUS) * HOVER_FORCE;
              p.vx += (dx / dist) * force; p.vy += (dy / dist) * force;
            }
          });
        }
      }

      function handlePress(clientX: number, clientY: number) {
  if (!interactionEnabled) return;
  if (isInsideHeroBox(clientX, clientY)) return; // click iniciado sobre el texto: no reacciona
  isDown = true;
}

      function handleRelease(clientX: number, clientY: number, triggerBurst = false) {
  if (!interactionEnabled) return;
  isDown = false;
  if (triggerBurst && !isInsideHeroBox(clientX, clientY)) {
    const mx = clientX;
    const my = clientY;
    particles.forEach(p => {
      const dx = p.x - mx, dy = p.y - my;
      const dist = Math.sqrt(dx * dx + dy * dy);
      if (dist < REPEL_RADIUS && dist > 0) {
        const force = (1 - dist / REPEL_RADIUS) * REPEL_FORCE;
        p.vx += (dx / dist) * force; p.vy += (dy / dist) * force;
        p.life = 0; p.maxLife = rand(200, 500);
      }
    });
    particles.push(...Array.from({ length: BURST_COUNT }, () => makeBurstParticle(mx, my)));
  }
}

      window.addEventListener('mousedown', (e) => handlePress(e.clientX, e.clientY));
      window.addEventListener('mouseup', (e) => handleRelease(e.clientX, e.clientY, true));
      window.addEventListener('mousemove', (e) => handleMove(e.clientX, e.clientY));

      window.addEventListener('touchstart', (e) => {if (e.touches.length > 0) handlePress(e.touches[0].clientX, e.touches[0].clientY);}, { passive: true });

      window.addEventListener('touchmove', (e) => {
        if (e.touches.length > 0) handleMove(e.touches[0].clientX, e.touches[0].clientY);
      }, { passive: true });

      window.addEventListener('touchend', (e) => {
        if (e.changedTouches.length > 0) {
          handleRelease(e.changedTouches[0].clientX, e.changedTouches[0].clientY, true);
        }
      }, { passive: true });

      function drawFrame() {
        ctx.fillStyle = 'rgba(0,0,0,0.50)';
        ctx.fillRect(0, 0, W, H);

        for (let i = particles.length - 1; i >= 0; i--) {
          const p = particles[i];
          p.life++;
          if (p.drag !== undefined) { p.vx *= p.drag; p.vy *= p.drag; }
          p.x += p.vx; p.y += p.vy;
          const progress = p.life / p.maxLife;
          const fade = progress < 0.1 ? progress / 0.1 : progress > 0.8 ? (1 - progress) / 0.2 : 1;

          ctx.beginPath();
          ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
          ctx.fillStyle = `hsla(${p.hue},${p.sat}%,${p.lit}%,${p.alpha * fade})`;
          ctx.fill();

          if (p.life >= p.maxLife) {
            if (p.drag !== undefined) particles.splice(i, 1);
            else particles[i] = makeParticle();
          } else if (p.drag === undefined && (p.x < -10 || p.x > W + 10 || p.y < -10 || p.y > H + 10)) {
            particles[i] = makeParticle();
          }
        }

        requestAnimationFrame(drawFrame);
      }

      function startCanvas() {
        resize();
        initParticles();
        drawFrame();
      }

      let resizeTimeout: ReturnType<typeof setTimeout>;
window.addEventListener('resize', () => {
  clearTimeout(resizeTimeout);
  resizeTimeout = setTimeout(() => { resize(); initParticles(); updateHeroBoxRect(); }, 200);
}, { passive: true });

window.addEventListener('scroll', updateHeroBoxRect, { passive: true });

startCanvas();
updateHeroBoxRect();

// El layout del hero puede moverse levemente cuando cargan las webfonts
// (Montserrat, etc.), así que reconsultamos el rect un par de veces más.
setTimeout(updateHeroBoxRect, 300);
setTimeout(updateHeroBoxRect, 1000);

      // ─── FADE PROGRESIVO + DESACTIVAR INTERACCIÓN FUERA DEL HERO ───────
      // Mientras el Hero está en pantalla: opacidad 1, interacción activa.
      // A medida que scrolleás hacia Works/SobreMi: opacidad baja gradualmente
      // hasta un mínimo, y la interacción se apaga apenas el Hero deja de
      // ocupar la mayoría de la pantalla.
      const MIN_OPACITY = 0.25;

      function setupFade() {
        const heroSection = document.getElementById('hero-section');
        if (!heroSection) {
          gsap.set(canvas, { opacity: MIN_OPACITY });
          interactionEnabled = false;
          return;
        }

        ScrollTrigger.create({
          trigger: heroSection,
          start: 'top top',
          end: 'bottom top',
          scrub: true,
          onUpdate(self) {
            // Si el texto del hero ya se reveló en mobile (por tap, no por
            // scroll), ese estado es definitivo para esta sesión de página:
            // el scroll nunca vuelve a tocar opacidad ni interactividad,
            // ni siquiera al volver a subir al hero.
            if (heroTextRevealedMobile) return;

            const progress = Math.min(Math.max(self.progress, 0), 1);
            const opacity = 1 - progress * (1 - MIN_OPACITY);
            gsap.set(canvas, { opacity });
            interactionEnabled = progress < 0.5;
          },
        });
      }

      window.addEventListener('DOMContentLoaded', setupFade);
      if (document.readyState !== 'loading') setupFade();
    </script>
  </body>
</html>